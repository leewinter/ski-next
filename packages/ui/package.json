{
  "name": "@ski-next/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/ski-next-ui.cjs",
  "module": "./dist/ski-next-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ski-next-ui.js",
      "require": "./dist/ski-next-ui.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "playwright test -c playwright-ct.config.ts"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "antd": "^5.21.6",
    "i18next": "^23.16.4",
    "react-i18next": "^15.1.0"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.48.2",
    "@playwright/test": "^1.48.2",
    "@ski-next/eslint-config": "*",
    "@ski-next/tsconfig": "*",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-storybook": "10.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "10.4.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
