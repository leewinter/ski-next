{
  "name": "@ski-next/web-components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": true,
  "main": "./dist/ski-next-web-components.iife.js",
  "module": "./dist/ski-next-web-components.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ski-next-web-components.js",
      "default": "./dist/ski-next-web-components.iife.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ski-next/ui": "*",
    "antd": "^5.21.6",
    "i18next": "^23.16.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0"
  },
  "devDependencies": {
    "@ski-next/eslint-config": "*",
    "@ski-next/tsconfig": "*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
